{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wallpaper Manager",
  "version": "0.1.0",
  "identifier": "com.wallpaper.manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run web:dev",
    "beforeBuildCommand": "bun run web:build"
  },
  "app": {
    "windows": [
      {
        "title": "Wallpaper Manager",
        "center": true,
        "width": 960,
        "height": 680,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:3000 http://localhost:3000"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "Walls",
    "copyright": "Copyright © 2026 Walls. MIT License.",
    "category": "Utility",
    "shortDescription": "Multi-Monitor Wallpaper Manager for Windows",
    "longDescription": "A lightweight desktop application for assigning and managing wallpapers across multiple monitors. Supports image files, solid colors, per-monitor fit modes, and reusable profiles.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "EnglishUS"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}